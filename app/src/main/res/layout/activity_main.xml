<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    tools:context=".MainActivity">

    <!-- Header / Custom Toolbar Superior -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:background="@drawable/bg_gradient_water"
        android:orientation="horizontal"
        android:padding="20dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvGreeting"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Olá, Usuário!"
                android:textColor="@color/white"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mantenha o hábito saudável"
                android:textColor="@color/blue_light"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Botão Sair -->
        <ImageButton
            android:id="@+id/btnSair"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="@color/white"
            android:contentDescription="Sair" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:fillViewport="true"
        android:clipToPadding="false"
        android:clipChildren="false"
        app:layout_constraintTop_toBottomOf="@id/headerLayout"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipToPadding="false"
            android:clipChildren="false"
            android:padding="20dp">

            <!-- Card de Progresso Diário -->
            <LinearLayout
                android:id="@+id/cardProgresso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:elevation="6dp"
                android:padding="24dp"
                android:layout_marginBottom="20dp"
                android:layout_marginTop="-30dp"> <!-- Efeito flutuante sobre o header -->

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Consumo de Hoje"
                        android:textColor="@color/text_dark"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_alignParentStart="true" />

                    <TextView
                        android:id="@+id/tvPorcentagem"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/blue_primary"
                        android:textSize="18sp"
                        android:textStyle="bold"
                        android:layout_alignParentEnd="true" />
                </RelativeLayout>

                <!-- Barra de Progresso Horizontal -->
                <ProgressBar
                    android:id="@+id/progressBarAgua"
                    style="@android:style/Widget.ProgressBar.Horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="14dp"
                    android:max="100"
                    android:progress="0"
                    android:progressTint="@color/blue_primary"
                    android:progressBackgroundTint="@color/blue_light"
                    android:layout_marginBottom="16dp" />

                <!-- Texto detalhado: Ex: "Você bebeu 1200ml de 2000ml hoje" -->
                <TextView
                    android:id="@+id/tvProgressoTexto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Você bebeu 0ml de 0ml hoje"
                    android:textColor="@color/text_dark"
                    android:textSize="15sp"
                    android:gravity="center" />

            </LinearLayout>

            <!-- Seção de Ações Rápidas (Copos de Água) -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar Água"
                android:textColor="@color/text_dark"
                android:textSize="16sp"
                android:textStyle="bold"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="24dp">

                <!-- Botão 250ml -->
                <LinearLayout
                    android:id="@+id/btnAgua250"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:background="@drawable/bg_button_quick_action"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_water_glass"
                        android:layout_marginBottom="4dp"
                        android:contentDescription="Copo de água" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ 250ml"
                        android:textColor="@color/blue_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <!-- Botão 500ml -->
                <LinearLayout
                    android:id="@+id/btnAgua500"
                    android:layout_width="0dp"
                    android:layout_height="110dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:background="@drawable/bg_button_quick_action"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_water_bottle"
                        android:layout_marginBottom="4dp"
                        android:contentDescription="Garrafa de água" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ 500ml"
                        android:textColor="@color/blue_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>

            <!-- Card de Resumo Semanal com Gráfico Dinâmico -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_card_white"
                android:orientation="vertical"
                android:elevation="6dp"
                android:padding="20dp"
                android:layout_marginBottom="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Histórico dos Últimos 7 Dias"
                    android:textColor="@color/text_dark"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp" />

                <!-- O Container do Gráfico: 7 colunas (uma para cada dia) -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="140dp"
                    android:orientation="horizontal"
                    android:gravity="bottom"
                    android:layout_marginBottom="16dp">

                    <!-- Dia 1 (Mais antigo) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay1"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay1"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 2 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay2"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay2"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 3 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay3"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay3"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 4 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay4"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay4"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 5 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay5"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay5"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 6 -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay6"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay6"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                    <!-- Dia 7 (Hoje - Mais recente) -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:padding="2dp">

                        <TextView
                            android:id="@+id/tvValDay7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="9sp"
                            android:textColor="@color/text_light"
                            android:layout_marginBottom="4dp" />

                        <FrameLayout
                            android:layout_width="14dp"
                            android:layout_height="80dp"
                            android:background="@drawable/bg_chart_bar_track">

                            <View
                                android:id="@+id/viewFillDay7"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_gravity="bottom"
                                android:background="@drawable/bg_chart_bar_fill" />
                        </FrameLayout>

                        <TextView
                            android:id="@+id/tvLabelDay7"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="-"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"
                            android:textStyle="bold"
                            android:layout_marginTop="6dp" />
                    </LinearLayout>

                </LinearLayout>

                <TextView
                    android:id="@+id/tvResumoSemanal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Total bebido nos últimos 7 dias: 0 ml"
                    android:textColor="@color/text_light"
                    android:textSize="14sp"
                    android:gravity="center" />
            </LinearLayout>

        </LinearLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
